ANTHROPIC_API_KEY=   # Required. Get from platform.claude.com (or provider equivalent)
ANTHROPIC_BASE_URL=  # Optional. Override API base URL (e.g. https://api.deepseek.com/anthropic for DeepSeek)
AI_MODEL=            # Optional. Defaults to claude-haiku-4-5-20251001 (e.g. deepseek-v4-flash for DeepSeek)

# Benchmark script (scripts/benchmark.js) — run with: npm run benchmark
CLAUDE_API_KEY=      # Optional. Defaults to ANTHROPIC_API_KEY
CLAUDE_MODEL=        # Optional. Defaults to claude-haiku-4-5-20251001
DEEPSEEK_API_KEY=    # Required for DeepSeek in benchmark. Get from platform.deepseek.com
DEEPSEEK_MODEL=      # Optional. Defaults to deepseek-v4-flash
POSTHOG_API_KEY=     # Optional. Enables analytics and LLM observability. Get from posthog.com
POSTHOG_HOST=        # Optional. Defaults to https://us.i.posthog.com (use https://eu.i.posthog.com for EU cloud)
PORT=3000            # Optional, defaults to 3000
HOST=127.0.0.1       # Optional, defaults to 127.0.0.1 (Tailscale Serve handles external access)
