[Unit]
Description=Newsdesk news reader
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/newsdesk
EnvironmentFile=/home/ubuntu/newsdesk/.env
ExecStart=/usr/bin/node --import ./dist/instrumentation.js dist/index.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
