{
  "name": "newsdesk",
  "version": "0.1.0",
  "description": "Personal news reader with AI-powered relevance filtering",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env --import ./src/instrumentation.ts src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env --import ./dist/instrumentation.js dist/index.js",
    "typecheck": "tsc --noEmit",
    "benchmark": "tsx --env-file=.env scripts/benchmark.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@posthog/ai": "^7.21.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.0.0",
    "fastify": "^5.3.3",
    "node-cron": "^4.2.1",
    "posthog-node": "^5.36.4",
    "rss-parser": "^3.13.0",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "protobufjs@7.6.2": true
  }
}
